def extract_review(review: dict, error_context: str | None = None) -> dict:
    user_content = f"Review ID: {review['id']}\nStar rating: {review['stars']}/5\n\n{review['text']}"

    if error_context:
        user_content = f"{error_context}\n\n---\n\nOriginal review:\n{user_content}"

    response = client.messages.create(
        model="claude-sonnet-4-6",
        max_tokens=1000,
        tools=[EXTRACTION_TOOL],
        tool_choice={"type": "tool", "name": "extract_review"},  # TODO: confirm this is correct
        messages=[
            {"role": "user", "content": user_content}
        ]
    )

    # TODO: pull the structured data out of response.content
    # Hint: iterate response.content and find the block where block.type == "tool_use"
    # The extracted data is in block.input (already a dict — no json.loads needed)
    for block in response.content:
        if block.type == "tool_use":
            return block.input

    raise ValueError(f"No tool_use block found in response for review {review['id']}")


if __name__ == "__main__":
    # Test on first 3 reviews
    for review in REVIEWS[:3]:
        result = extract_review(review)
