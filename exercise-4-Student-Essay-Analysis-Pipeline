            # TODO: list all required fields
        ]
    }
}

SYSTEM_PROMPT = """You are an experienced secondary school English teacher.
Grade student essays fairly and consistently. Be specific — always reference
the actual essay content in your feedback. Never invent quotes or examples
that do not appear in the essay.

Scoring guide:
1-3: Below expectations — major gaps in the criterion
4-5: Approaching expectations — partial achievement with clear gaps
6-7: Meeting expectations — solid work with some room to improve
8-9: Exceeding expectations — strong work, minor refinements possible
10:  Exceptional — publishable quality for this age group"""


# ── AGENTIC LOOP ─────────────────────────────────────────────────────────────

def grade_essay(essay: dict, extra_context: str | None = None) -> dict:
    """
    Run the agentic grading loop for a single essay.
    Continues iterating while stop_reason == "tool_use".
    Terminates when stop_reason == "end_turn".
    """
    user_content = (
        f"Grade Level: {essay['grade_level']}\n"
        f"Essay Prompt: {essay['prompt']}\n\n"
        f"Student Essay:\n{essay['text']}"
    )
    if extra_context:
        user_content = f"{extra_context}\n\n---\n\n{user_content}"

    messages = [{"role": "user", "content": user_content}]

    # TODO: implement the agentic loop
    # Key steps:
    # 1. Call client.messages.create() with the grading tool and forced tool_choice
    # 2. Check response.stop_reason
    # 3. If "tool_use": find the tool_use block, extract block.input, return it
    # 4. If "end_turn": the model returned text instead of using the tool — this
    #    should not happen with forced tool_choice, but handle it gracefully
    # 5. Append assistant response and tool result to messages for next iteration
    #    (for this single-tool task, the loop will complete in one iteration)

    while True:
        response = client.messages.create(
            model="claude-sonnet-4-6",
            max_tokens=1500,
            system=SYSTEM_PROMPT,
            tools=[GRADING_TOOL],
            tool_choice={"type": "tool", "name": "grade_essay"},
            messages=messages
        )

        # TODO: inspect response.stop_reason and handle each case
        # Hint: response.stop_reason will be "tool_use" since we forced the tool
        # Find the tool_use block: next(b for b in response.content if b.type == "tool_use")
        pass


if __name__ == "__main__":
    for essay in ESSAYS[:2]:
        print(f"\n{'='*60}")
        print(f"Grading {essay['id']} — {essay['student']}")
        result = grade_essay(essay)
        print(json.dumps(result, indent=2))
        time.sleep(1)
